# Copy this file to .env and fill in local credentials.
# Never commit .env or service-account JSON files.

# NAVER CLOVA Studio (HCX-005)
CLOVA_API_KEY=Bearer <your-clova-api-key>
NAVER_SERVICE_API_KEY=<your-naver-service-api-key>

# OpenAI
OPENAI_API_KEY=<your-openai-api-key>

# Google Cloud / Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\qjatj\Desktop\Paperproject\<your-service-account>.json
GOOGLE_CLOUD_PROJECT=<your-google-cloud-project>
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# Claude/Sonnet through Vertex AI
SONNET_VIA_VERTEX=True
SONNET_VERTEX_MODEL=claude-sonnet-4-5@20250929

# Anthropic direct API.
# Leave unset if Claude/Sonnet is evaluated through Vertex AI after the client code is updated.
ANTHROPIC_API_KEY=<your-anthropic-api-key>
